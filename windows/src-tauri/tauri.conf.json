{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WeChat Long Pic",
  "version": "1.0.0",
  "identifier": "studio.upperocean.wechatlongpic",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WeChat Long Pic",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Compose vertical long pictures with a centered thumbnail",
    "longDescription": "Stitch several photos top-to-bottom into one long picture, with the chosen thumbnail placed at the exact geometric center so messaging apps that crop the middle as a preview will show your chosen image."
  }
}
